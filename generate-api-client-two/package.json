{
  "name": "@swagger-ts/api-client-two",
  "version": "1.0.0",
  "description": "Generated TypeScript API client from Swagger documentation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "ts-node --compiler-options '{\"module\":\"commonjs\"}' src/index.ts",
    "build": "npm run generate && tsc && npm run minify",
    "minify": "terser dist/Api.js -o dist/Api.js --compress --mangle && terser dist/index.js -o dist/index.js --compress --mangle",
    "publish:local": "npm run build && yalc publish"
  },
  "files": [
    "dist/**/*"
  ],
  "devDependencies": {
    "@types/node": "^20.19.37",
    "dotenv": "^16.0.3",
    "swagger-typescript-api": "^13.2.18",
    "terser": "^5.36.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "eta": "^4.5.1"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "typescript": "^4.9.0 || ^5.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
