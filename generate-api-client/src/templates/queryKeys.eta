
const QUERY_KEYS = {
<% for (let route of it.routes) { %>
  <% if (route.httpMethod === "get" && route.pathParams.length === 0) { %>
  list: ["<%= it.entityName.toLowerCase() %>List"] as const,
  <% } %>
  <% if (route.httpMethod === "get" && route.pathParams.length > 0) { %>
  detail: (<%= route.pathParams.map(p => `${p.name}: ${p.type}`).join(", ") %>) => ["<%= it.entityName.toLowerCase() %>Detail", <%= route.pathParams.map(p => p.name).join(", ") %>] as const,
  <% } %>
<% } %>
};
