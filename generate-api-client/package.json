{
  "name": "@swagger-ts/api-client",
  "version": "1.0.0",
  "description": "Generated TypeScript API client from Swagger documentation",
  "main": "dist/Api.js",
  "types": "dist/Api.d.ts",
  "scripts": {
    "generate": "ts-node --compiler-options '{\"module\":\"commonjs\"}' src/generate.ts",
    "build": "npm run generate && tsc",
    "dev": "npm run generate && tsc --watch",
    "publish:local": "npm run build && yalc publish"
  },
  "files": [
    "dist/**/*"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "dotenv": "^16.0.3",
    "swagger-typescript-api": "^13.2.18",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  },
  "dependencies": {},
  "peerDependencies": {
    "typescript": "^4.9.0 || ^5.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
